{
  "policy_id": "default_governance_v1",
  "version": "1.0.0",
  "name": "Default Governance Policy",
  "description": "Balanced default policy for general tabular binary classification audits.",
  "fairness_thresholds": {
    "demographic_parity_difference": {
      "medium": 0.1,
      "high": 0.2,
      "critical": 0.3
    },
    "equalized_odds_difference": {
      "medium": 0.1,
      "high": 0.2,
      "critical": 0.3
    },
    "disparate_impact_ratio": {
      "warning_below": 0.8,
      "critical_below": 0.5
    },
    "representation_ratio": {
      "warning_below": 0.8,
      "critical_below": 0.5
    },
    "proxy_variable_strength": {
      "warning_above": 0.5,
      "critical_above": 0.8
    }
  },
  "severity_weights": {
    "demographic_parity_difference": 0.24,
    "equalized_odds_difference": 0.24,
    "disparate_impact_ratio": 0.14,
    "proxy_variable_risk": 0.14,
    "underrepresentation": 0.12,
    "small_group_uncertainty": 0.06,
    "conditional_fairness_gap": 0.06
  },
  "severity_thresholds": {
    "medium_at_or_above": 0.28,
    "high_at_or_above": 0.5,
    "critical_at_or_above": 0.72
  },
  "deployment_decision_thresholds": {
    "safe_to_deploy_below": 0.25,
    "needs_review_below": 0.55
  },
  "model_selection": {
    "accuracy_metric": "balanced_accuracy",
    "weights": {
      "balanced_accuracy": 0.55,
      "demographic_parity_difference": 0.15,
      "equalized_odds_difference": 0.2,
      "disparate_impact_ratio": 0.1
    },
    "minimum_recall": 0.55,
    "maximum_equalized_odds_gap": 0.35,
    "maximum_demographic_parity_gap": 0.35,
    "minimum_disparate_impact_ratio": 0.45
  },
  "grouping_rules": {
    "age": {
      "type": "fixed_bins",
      "bins": [0, 25, 45, 65, 200],
      "labels": ["Under 25", "25-44", "45-64", "65+"]
    },
    "default_numeric": {
      "type": "quantile",
      "q": 4
    },
    "default_categorical": {
      "type": "top_k_plus_other",
      "top_k": 10
    }
  },
  "report_defaults": {
    "template": "full_report"
  }
}

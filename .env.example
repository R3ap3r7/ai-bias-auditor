# Copy this file to .env for local development.
# Never commit real API keys.
GEMINI_API_KEY=replace-with-your-google-ai-studio-key
# Optional. Used only for the narrative analysis report. Defaults to gemini-2.5-flash in the app.
GEMINI_MODEL=gemini-2.5-flash
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5050,http://localhost:8080,http://localhost:5173,http://127.0.0.1:5050

# Flutter web Firebase configuration. The Firebase web API key is intentionally
# passed at build/run time instead of committed into source.
FIREBASE_API_KEY=replace-with-your-firebase-web-api-key
FIREBASE_PROJECT_ID=ai-bias-auditor-2604171603
FIREBASE_APP_ID=1:49788943765:web:b1682c0470abd4cab84a9c
FIREBASE_MESSAGING_SENDER_ID=49788943765
FIREBASE_AUTH_DOMAIN=ai-bias-auditor-2604171603.firebaseapp.com
FIREBASE_STORAGE_BUCKET=ai-bias-auditor-2604171603.firebasestorage.app

# Copy this file to .env for local development.
# Never commit real API keys.
GEMINI_API_KEY=replace-with-your-google-ai-studio-key
# Optional. Used only for the narrative analysis report. Defaults to gemini-2.5-flash in the app.
GEMINI_MODEL=gemini-2.5-flash
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:8080,http://localhost:5173

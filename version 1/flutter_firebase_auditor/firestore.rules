rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasUserProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function ownsDocument() {
      return signedIn() && request.auth.uid == resource.data.ownerId;
    }

    function createsOwnedDocument() {
      return hasUserProfile()
        && request.auth.uid == request.resource.data.ownerId;
    }

    match /users/{userId} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId;
      allow read: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId;
      allow delete: if false;
    }

    match /auditRuns/{auditId} {
      allow create: if createsOwnedDocument();
      allow read, update, delete: if ownsDocument();

      match /traceRecords/{traceId} {
        allow create: if signedIn()
          && exists(/databases/$(database)/documents/auditRuns/$(auditId))
          && get(/databases/$(database)/documents/auditRuns/$(auditId)).data.ownerId == request.auth.uid;
        allow read, update, delete: if signedIn()
          && exists(/databases/$(database)/documents/auditRuns/$(auditId))
          && get(/databases/$(database)/documents/auditRuns/$(auditId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
